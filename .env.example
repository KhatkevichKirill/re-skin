# ============================================================
# re-skin — environment template (safe to commit)
# Copy to .env and fill in real values.
# ============================================================

# --- kie.ai (Seedance) ---
KIE_API_KEY=

# --- Google Drive (service account) ---
# Place service-account JSON at the path below; SA needs write access to target folder(s).
GOOGLE_SERVICE_ACCOUNT_FILE=./secrets/gdrive-sa.json
GDRIVE_DEFAULT_FOLDER_ID=

# --- Web access (Nginx basic auth) ---
BASIC_AUTH_USER=
BASIC_AUTH_PASS=
APP_EXTERNAL_PORT=8847

# --- Infra ---
# Set a strong password (e.g. `openssl rand -hex 24`) and reference it in REDIS_URL.
REDIS_PASSWORD=
REDIS_URL=redis://:REDIS_PASSWORD@redis:6379/0

# --- PostgreSQL (production) ---
# Generate a strong password: openssl rand -hex 24
# These are consumed by the `db` service in docker-compose.yml.
POSTGRES_USER=reskin
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
POSTGRES_DB=reskin

# DATABASE_URL for Postgres (set this when cutting over from SQLite):
#DATABASE_URL=postgresql+psycopg2://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}

# DATABASE_URL for SQLite (default — keep for local dev / tests):
DATABASE_URL=sqlite:///./data/app.db

# --- App config ---
DEFAULT_RESOLUTION=480p
MAX_REFERENCE_IMAGES=2
SEGMENT_MAX_SECONDS=15
